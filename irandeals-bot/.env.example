BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_IDS=123456789,987654321
PUBLIC_CHANNEL_ID=@IranDeals

# Webhook mode (production): set WEBHOOK_URL to your public HTTPS base URL
# Leave unset for long-polling (development/local)
# WEBHOOK_URL=https://your-app.railway.app
# WEBHOOK_SECRET=random-secret-string

DATABASE_URL=postgresql://irandeals:irandeals@db:5432/irandeals
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-this-to-a-random-32-char-secret
JWT_EXPIRES_IN=7d
API_PORT=3000
NODE_ENV=development

# Business rules (optional — defaults shown)
MAX_DEALS_PER_WEEK=5
MAX_INSTANT_PER_DAY=3
